<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1200 630" width="1200" height="630">
  <defs>
    <linearGradient id="bg" x1="0" y1="0" x2="1200" y2="630" gradientUnits="userSpaceOnUse">
      <stop offset="0%" stop-color="#0a0f1e"/>
      <stop offset="100%" stop-color="#0f1929"/>
    </linearGradient>
    <linearGradient id="accent" x1="0" y1="0" x2="400" y2="400" gradientUnits="userSpaceOnUse">
      <stop offset="0%" stop-color="#06b6d4"/>
      <stop offset="100%" stop-color="#0284c7"/>
    </linearGradient>
    <radialGradient id="glow" cx="30%" cy="40%" r="50%">
      <stop offset="0%" stop-color="#06b6d4" stop-opacity="0.12"/>
      <stop offset="100%" stop-color="#06b6d4" stop-opacity="0"/>
    </radialGradient>
  </defs>
  <rect width="1200" height="630" fill="url(#bg)"/>
  <rect width="1200" height="630" fill="url(#glow)"/>
  <!-- Grid lines -->
  <g opacity="0.04" stroke="#06b6d4" stroke-width="1">
    <line x1="0" y1="60" x2="1200" y2="60"/>
    <line x1="0" y1="120" x2="1200" y2="120"/>
    <line x1="0" y1="180" x2="1200" y2="180"/>
    <line x1="0" y1="240" x2="1200" y2="240"/>
    <line x1="0" y1="300" x2="1200" y2="300"/>
    <line x1="0" y1="360" x2="1200" y2="360"/>
    <line x1="0" y1="420" x2="1200" y2="420"/>
    <line x1="0" y1="480" x2="1200" y2="480"/>
    <line x1="0" y1="540" x2="1200" y2="540"/>
    <line x1="0" y1="600" x2="1200" y2="600"/>
    <line x1="60" y1="0" x2="60" y2="630"/>
    <line x1="120" y1="0" x2="120" y2="630"/>
    <line x1="180" y1="0" x2="180" y2="630"/>
    <line x1="240" y1="0" x2="240" y2="630"/>
    <line x1="300" y1="0" x2="300" y2="630"/>
    <line x1="360" y1="0" x2="360" y2="630"/>
    <line x1="420" y1="0" x2="420" y2="630"/>
    <line x1="480" y1="0" x2="480" y2="630"/>
    <line x1="540" y1="0" x2="540" y2="630"/>
    <line x1="600" y1="0" x2="600" y2="630"/>
    <line x1="660" y1="0" x2="660" y2="630"/>
    <line x1="720" y1="0" x2="720" y2="630"/>
    <line x1="780" y1="0" x2="780" y2="630"/>
    <line x1="840" y1="0" x2="840" y2="630"/>
    <line x1="900" y1="0" x2="900" y2="630"/>
    <line x1="960" y1="0" x2="960" y2="630"/>
    <line x1="1020" y1="0" x2="1020" y2="630"/>
    <line x1="1080" y1="0" x2="1080" y2="630"/>
    <line x1="1140" y1="0" x2="1140" y2="630"/>
  </g>
  <!-- Logo -->
  <rect x="80" y="80" width="52" height="52" rx="14" fill="url(#accent)"/>
  <path d="M92 122V102l14 12 14-12v20" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round" fill="none"/>
  <!-- Brand name -->
  <text x="148" y="116" font-family="system-ui, sans-serif" font-size="28" font-weight="700" fill="white">NorthPixel</text>
  <!-- Main headline -->
  <text x="80" y="280" font-family="system-ui, sans-serif" font-size="72" font-weight="800" fill="white">Fast Websites</text>
  <text x="80" y="368" font-family="system-ui, sans-serif" font-size="72" font-weight="800" fill="url(#accent)">for Small Business</text>
  <!-- Subtitle -->
  <text x="80" y="440" font-family="system-ui, sans-serif" font-size="26" fill="#94a3b8">Professional websites delivered in 3–14 days · Tallinn, Estonia</text>
  <!-- Badges -->
  <rect x="80" y="500" width="180" height="44" rx="22" fill="rgba(6,182,212,0.1)" stroke="rgba(6,182,212,0.3)" stroke-width="1"/>
  <text x="170" y="527" font-family="system-ui, sans-serif" font-size="15" font-weight="600" fill="#06b6d4" text-anchor="middle">3–14 Days</text>
  <rect x="276" y="500" width="160" height="44" rx="22" fill="rgba(6,182,212,0.1)" stroke="rgba(6,182,212,0.3)" stroke-width="1"/>
  <text x="356" y="527" font-family="system-ui, sans-serif" font-size="15" font-weight="600" fill="#06b6d4" text-anchor="middle">Fixed Price</text>
  <rect x="452" y="500" width="200" height="44" rx="22" fill="rgba(6,182,212,0.1)" stroke="rgba(6,182,212,0.3)" stroke-width="1"/>
  <text x="552" y="527" font-family="system-ui, sans-serif" font-size="15" font-weight="600" fill="#06b6d4" text-anchor="middle">100% Satisfaction</text>
  <!-- URL -->
  <text x="1120" y="590" font-family="system-ui, sans-serif" font-size="18" fill="#334155" text-anchor="end">northpixel.vercel.app</text>
</svg>
